@{
    ViewData["Title"] = "Page Not Found";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="notfound-page">
    <div class="notfound-numbers">
        <span class="notfound-num">4</span>
        <div class="notfound-icon-wrap">
            <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="notfound-svg" aria-hidden="true">
                <!-- Running figure -->
                <rect x="80" y="30" width="60" height="100" rx="8" fill="white" stroke="#E5E5E5" stroke-width="2" />
                <rect x="90" y="10" width="40" height="10" rx="3" fill="#D6EB31" />
                <text x="100" y="62" font-family="monospace" font-size="16" font-weight="bold" fill="#1a1a1a" text-anchor="middle">15:02</text>
                <rect x="88" y="70" width="44" height="3" rx="2" fill="#D6EB31" />
                <!-- Watch -->
                <rect x="115" y="95" width="30" height="30" rx="6" fill="#D6EB31" />
                <text x="130" y="108" font-family="monospace" font-size="7" fill="white" text-anchor="middle">❤</text>
                <text x="130" y="118" font-family="monospace" font-size="7" fill="white" text-anchor="middle">💧</text>
                <!-- Runner -->
                <circle cx="72" cy="75" r="14" fill="#1a1a1a" />
                <path d="M72 89 L65 115 L78 115" stroke="#1a1a1a" stroke-width="5" stroke-linecap="round" fill="none" />
                <path d="M72 89 L60 105" stroke="#1a1a1a" stroke-width="5" stroke-linecap="round" fill="none" />
                <path d="M72 89 L82 100 L72 115" stroke="#1a1a1a" stroke-width="4" stroke-linecap="round" fill="none" />
            </svg>
        </div>
        <span class="notfound-num">4</span>
    </div>
    <h1 class="notfound-title">Oops! page not found</h1>
    <p class="notfound-subtitle">The page you are looking for does not exists.</p>
    <a href="/" class="notfound-btn">
        Back to Homepage
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
    </a>
</div>

