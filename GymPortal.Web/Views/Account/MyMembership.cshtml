@model GymPortal.Application.DTOs.UserDto
@{
    ViewData["Title"] = "My Membership";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="account-page-new">
    <h1 class="account-page-heading">My Account</h1>

    <div class="account-layout">
        <!-- ═══ Sidebar ═══ -->
        <aside class="account-sidebar">
            <div class="account-avatar-card">
                <img src="@(string.IsNullOrEmpty(Model?.ProfileImageUrl) ? "/images/trainer-profile.png" : Model.ProfileImageUrl)"
                     alt="Profile photo" />
            </div>

            <div class="account-menu-card">
                <div class="account-menu-header">
                    <span class="account-menu-title">Menu Options</span>
                </div>
                <nav class="account-menu-list" aria-label="Account navigation">
                    <a href="/Account/MyAccount" class="account-menu-item">
                        <span class="account-menu-item-text">About Me</span>
                        <svg class="account-menu-item-arrow" width="13" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg>
                    </a>
                    <a href="/Account/MyMembership" class="account-menu-item active" aria-current="page">
                        <span class="account-menu-item-text">My Membership</span>
                        <svg class="account-menu-item-arrow" width="13" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg>
                    </a>
                    <a href="/Account/MyBookings" class="account-menu-item">
                        <span class="account-menu-item-text">My Bookings</span>
                        <svg class="account-menu-item-arrow" width="13" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg>
                    </a>
                    <form method="post" action="/Account/SignOut" style="display:contents">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="account-menu-item" style="border-bottom:1px solid #E6E6E6">
                            <span class="account-menu-item-text">Sign Out</span>
                            <svg class="account-menu-item-arrow" width="13" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg>
                        </button>
                    </form>
                </nav>
                <p class="account-menu-remove-note">If you like to cancel your account click below</p>
                <form method="post" action="/Account/DeleteAccount" onsubmit="return confirm('Are you sure you want to delete your account? This action cannot be undone.')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="account-menu-remove">Remove Account</button>
                </form>
            </div>
        </aside>

        <!-- ═══ Main content ═══ -->
        <div>
            <div class="account-form-card">
                <h2 class="account-form-title">My Membership</h2>
                <hr class="account-form-divider" />

                @if (!string.IsNullOrEmpty(Model?.MembershipPlanName))
                {
                    <div style="margin-bottom:24px">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;flex-wrap:wrap;gap:12px">
                            <span class="auth-label" style="margin:0;font-size:16px">Current Plan</span>
                            <span style="background:#D6EB31;color:#111;font-weight:600;padding:4px 16px;border-radius:20px;font-size:14px">Active</span>
                        </div>
                        <p style="font-size:24px;font-weight:700;color:#111;margin:0 0 8px">@Model.MembershipPlanName</p>
                        @if (Model.MembershipEndDate.HasValue)
                        {
                            <p style="color:#6F6F6F;font-size:14px;margin:0">
                                Expires on @Model.MembershipEndDate.Value.ToString("MMMM d, yyyy")
                            </p>
                        }
                    </div>

                    <hr class="account-form-divider" />

                    <div style="display:flex;gap:12px;margin-top:24px;flex-wrap:wrap">
                        <a href="/Membership" class="account-save-btn" style="text-decoration:none;display:inline-flex;align-items:center;gap:8px">
                            Upgrade Plan
                            <svg width="13" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg>
                        </a>
                        <form method="post" action="/Membership/Cancel" onsubmit="return confirm('Are you sure you want to cancel your membership?')">
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    style="background:transparent;border:1px solid #E50004;color:#E50004;padding:12px 24px;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;transition:all 0.2s"
                                    onmouseover="this.style.backgroundColor='#E50004';this.style.color='white'"
                                    onmouseout="this.style.backgroundColor='transparent';this.style.color='#E50004'">
                                Cancel Membership
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <div style="text-align:center;padding:48px 0">
                        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#D6EB31" stroke-width="1.5" style="margin-bottom:16px">
                            <path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z" />
                            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />
                        </svg>
                        <p style="font-size:18px;font-weight:600;color:#111;margin:0 0 8px">No Active Membership</p>
                        <p style="color:#6F6F6F;font-size:14px;margin:0 0 24px">You don't have an active membership plan. Join now to get started!</p>
                        <a href="/Membership" class="account-save-btn" style="text-decoration:none;display:inline-flex;align-items:center;gap:8px">
                            View Plans
                            <svg width="13" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            alert('@TempData["Success"]');
        });
    </script>
}

@if (TempData["Error"] != null)
{
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            alert('@TempData["Error"]');
        });
    </script>
}

