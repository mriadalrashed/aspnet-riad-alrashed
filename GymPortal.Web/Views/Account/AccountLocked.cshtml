@{
    ViewData["Title"] = "Account Locked";
}

<div class="auth-page">
    <div class="auth-card" style="text-align:center; padding:60px">
        <div style="width:80px; height:80px; background:#FEE2E2; border-radius:50%; margin:0 auto 24px; display:flex; align-items:center; justify-content:center">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#B91C1C" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
        </div>

        <h1 class="auth-title" style="font-size:32px; margin-bottom:16px">Account Locked</h1>
        <p class="auth-description" style="margin-bottom:32px">
            Too many failed login attempts. Your account has been temporarily locked.
            Please wait a few minutes and try again.
        </p>

        <a href="/Account/SignIn" class="auth-submit" style="display:inline-flex; width:auto; padding:0 40px; text-decoration:none">
            Try Again
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
        </a>
    </div>
</div>

