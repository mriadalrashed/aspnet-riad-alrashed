@model GymPortal.Web.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-page">
    <div class="auth-card">
        <h1 class="auth-title">Reset Your Password</h1>
        <p class="auth-description">Enter the email address linked to your account and we'll send you a reset link.</p>
        <hr class="auth-divider" />
        @await Html.PartialAsync("_ValidationSummary")
        <form method="post" asp-action="ForgotPassword" asp-controller="Account" class="auth-form" novalidate>
            @Html.AntiForgeryToken()
            <div class="auth-form-group">
                <label asp-for="Email" class="auth-label"></label>
                <input asp-for="Email" class="auth-input" type="email" autocomplete="email" placeholder="you@example.com" required />
                <span asp-validation-for="Email" class="text-danger" style="font-size:12px;color:#B91C1C;margin-top:4px"></span>
            </div>
            <button type="submit" class="auth-submit">Send Reset Link</button>
        </form>
        <p class="auth-footer"><a href="/Account/SignIn" class="auth-link">← Back to Sign In</a></p>
    </div>
</div>

