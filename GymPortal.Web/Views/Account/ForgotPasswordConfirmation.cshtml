@{
    ViewData["Title"] = "Forgot Password Confirmation";
}

<div class="auth-page">
    <div class="auth-card" style="text-align:center; padding:60px">
        <div style="width:80px; height:80px; background:#D6EB31; border-radius:50%; margin:0 auto 24px; display:flex; align-items:center; justify-content:center">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#27252F" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
            </svg>
        </div>

        <h1 class="auth-title" style="font-size:32px; margin-bottom:16px">Check Your Email</h1>
        <p class="auth-description" style="margin-bottom:32px">
            If an account exists with the email you provided, we've sent instructions to reset your password.
            Please check your inbox and follow the link to reset your password.
        </p>

        <div style="margin-bottom:24px">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#6F6F6F" stroke-width="1.5">
                <rect x="2" y="4" width="20" height="16" rx="2" />
                <path d="M22 7L12 13 2 7" />
            </svg>
        </div>

        <p class="auth-footer">
            <a href="/Account/SignIn" class="auth-link">Return to Sign In</a>
        </p>

        <p class="auth-footer" style="margin-top:16px; font-size:14px">
            Didn't receive an email?
            <a href="/Account/ForgotPassword" class="auth-link">Try again</a>
        </p>
    </div>
</div>







