@* @model GymPortal.Web.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="auth-page">
    <div class="auth-card">
        <h1 class="auth-title">Reset Your Password</h1>
        <p class="auth-description">Enter your new password below.</p>
        <hr class="auth-divider" />

        @await Html.PartialAsync("_ValidationSummary")

        <form method="post" asp-action="ResetPassword" class="auth-form" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="Code" />

            <div class="auth-form-group">
                <label asp-for="Password" class="auth-label"></label>
                <div class="auth-password-wrapper">
                    <input asp-for="Password" class="auth-input" type="password" id="newPassword"
                           autocomplete="new-password" placeholder="Enter new password" required />
                    <button type="button" class="auth-password-toggle" onclick="togglePassword('newPassword')"
                            aria-label="Toggle password">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger" style="font-size:12px;color:#B91C1C;margin-top:4px"></span>
            </div>

            <div class="auth-form-group">
                <label asp-for="ConfirmPassword" class="auth-label"></label>
                <div class="auth-password-wrapper">
                    <input asp-for="ConfirmPassword" class="auth-input" type="password" id="confirmPassword"
                           autocomplete="new-password" placeholder="Confirm new password" required />
                    <button type="button" class="auth-password-toggle" onclick="togglePassword('confirmPassword')"
                            aria-label="Toggle password">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:12px;color:#B91C1C;margin-top:4px"></span>
            </div>

            <button type="submit" class="auth-submit">
                Reset Password
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
            </button>

            <p class="auth-footer">
                <a href="/Account/SignIn" class="auth-link">Back to Sign In</a>
            </p>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword(id) {
            var input = document.getElementById(id);
            input.type = input.type === 'password' ? 'text' : 'password';
        }
    </script>
}

 *@