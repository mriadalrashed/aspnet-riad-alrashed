@{
    ViewData["Title"] = "Store";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="store-page" style="max-width:1320px; margin:0 auto; padding:48px 16px;">
    <div style="text-align:center; margin-bottom:48px;">
        <h1 class="store-title" style="font-family:'Poppins',sans-serif; font-weight:700; font-size:48px; color:#27252F; margin-bottom:16px;">Our Store</h1>
        <p class="store-subtitle" style="font-family:'DM Sans',sans-serif; font-size:18px; color:#6F6F6F;">High quality fitness products built for results</p>
    </div>

    <div class="products-grid" style="display:grid; grid-template-columns:repeat(4,1fr); gap:24px;">
        <!-- Product 1 -->
        <div class="product-card" style="background:#fff; border-radius:16px; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
            <div style="height:250px; background:#F7F7F7; display:flex; align-items:center; justify-content:center;">
                <img src="/images/product-1.png" alt="Pro Weight Set" style="max-width:80%; max-height:80%; object-fit:contain;" />
            </div>
            <div style="padding:20px;">
                <h3 style="font-family:'Poppins',sans-serif; font-weight:600; font-size:18px; color:#27252F; margin-bottom:8px;">Pro Weight Set</h3>
                <p style="font-family:'DM Sans',sans-serif; font-size:14px; color:#6F6F6F; margin-bottom:16px;">Professional grade weight set for home gym</p>
                <div style="display:flex; align-items:center; justify-content:space-between;">
                    <span style="font-family:'Poppins',sans-serif; font-weight:700; font-size:24px; color:#D6EB31;">$129.99</span>
                    <a href="#" class="store-btn" style="background:#D6EB31; color:#27252F; border:none; border-radius:50px; padding:8px 20px; font-family:'DM Sans',sans-serif; font-weight:600; font-size:14px; text-decoration:none;">Add to Cart</a>
                </div>
            </div>
        </div>

        <!-- Product 2 -->
        <div class="product-card" style="background:#fff; border-radius:16px; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
            <div style="height:250px; background:#F7F7F7; display:flex; align-items:center; justify-content:center;">
                <img src="/images/product-2.png" alt="Gym Bag XL" style="max-width:80%; max-height:80%; object-fit:contain;" />
            </div>
            <div style="padding:20px;">
                <h3 style="font-family:'Poppins',sans-serif; font-weight:600; font-size:18px; color:#27252F; margin-bottom:8px;">Gym Bag XL</h3>
                <p style="font-family:'DM Sans',sans-serif; font-size:14px; color:#6F6F6F; margin-bottom:16px;">Spacious bag with separate shoe compartment</p>
                <div style="display:flex; align-items:center; justify-content:space-between;">
                    <span style="font-family:'Poppins',sans-serif; font-weight:700; font-size:24px; color:#D6EB31;">$49.99</span>
                    <a href="#" class="store-btn" style="background:#D6EB31; color:#27252F; border:none; border-radius:50px; padding:8px 20px; font-family:'DM Sans',sans-serif; font-weight:600; font-size:14px; text-decoration:none;">Add to Cart</a>
                </div>
            </div>
        </div>

        <!-- Product 3 -->
        <div class="product-card" style="background:#fff; border-radius:16px; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
            <div style="height:250px; background:#F7F7F7; display:flex; align-items:center; justify-content:center;">
                <img src="/images/product-3.png" alt="Smart Fitness Band" style="max-width:80%; max-height:80%; object-fit:contain;" />
            </div>
            <div style="padding:20px;">
                <h3 style="font-family:'Poppins',sans-serif; font-weight:600; font-size:18px; color:#27252F; margin-bottom:8px;">Smart Fitness Band</h3>
                <p style="font-family:'DM Sans',sans-serif; font-size:14px; color:#6F6F6F; margin-bottom:16px;">Track heart rate, steps, and calories</p>
                <div style="display:flex; align-items:center; justify-content:space-between;">
                    <span style="font-family:'Poppins',sans-serif; font-weight:700; font-size:24px; color:#D6EB31;">$79.99</span>
                    <a href="#" class="store-btn" style="background:#D6EB31; color:#27252F; border:none; border-radius:50px; padding:8px 20px; font-family:'DM Sans',sans-serif; font-weight:600; font-size:14px; text-decoration:none;">Add to Cart</a>
                </div>
            </div>
        </div>

        <!-- Product 4 -->
        <div class="product-card" style="background:#fff; border-radius:16px; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
            <div style="height:250px; background:#F7F7F7; display:flex; align-items:center; justify-content:center;">
                <img src="/images/product-4.png" alt="Treadmill Pro X" style="max-width:80%; max-height:80%; object-fit:contain;" />
            </div>
            <div style="padding:20px;">
                <h3 style="font-family:'Poppins',sans-serif; font-weight:600; font-size:18px; color:#27252F; margin-bottom:8px;">Treadmill Pro X</h3>
                <p style="font-family:'DM Sans',sans-serif; font-size:14px; color:#6F6F6F; margin-bottom:16px;">Commercial grade treadmill with incline</p>
                <div style="display:flex; align-items:center; justify-content:space-between;">
                    <span style="font-family:'Poppins',sans-serif; font-weight:700; font-size:24px; color:#D6EB31;">$899.99</span>
                    <a href="#" class="store-btn" style="background:#D6EB31; color:#27252F; border:none; border-radius:50px; padding:8px 20px; font-family:'DM Sans',sans-serif; font-weight:600; font-size:14px; text-decoration:none;">Add to Cart</a>
                </div>
            </div>
        </div>
    </div>
</div>

