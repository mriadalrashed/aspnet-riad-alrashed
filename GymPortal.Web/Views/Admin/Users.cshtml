@model IEnumerable<GymPortal.Application.DTOs.UserDto>
@{
    ViewData["Title"] = "Admin – Users";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="background-color:#F7F7F7;min-height:100vh;padding:32px 16px">
    <div class="container">

        <div style="margin-bottom:32px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px">
            <div>
                <h1 style="font-family:'Poppins',sans-serif;font-weight:700;font-size:2rem;color:#27252F;margin-bottom:8px">User Management</h1>
                <p style="font-family:'DM Sans',sans-serif;font-size:15px;color:#6F6F6F">View, change roles and delete user accounts.</p>
            </div>
            <a href="/Admin/Classes" style="display:inline-flex;align-items:center;gap:8px;background:#D6EB31;color:#27252F;border-radius:50px;padding:0 20px;height:44px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:15px;text-decoration:none">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2" />
                    <line x1="16" y1="2" x2="16" y2="6" />
                    <line x1="8" y1="2" x2="8" y2="6" />
                    <line x1="3" y1="10" x2="21" y2="10" />
                </svg>
                Manage Classes
            </a>
        </div>

        <!-- Stats bar -->
        <div style="display:flex;gap:16px;margin-bottom:32px;flex-wrap:wrap">
            @{
                var totalUsers = Model.Count();
                var admins = Model.Count(u => u.Role == "Admin");
                var members = Model.Count(u => u.Role == "Member");
            }
            <div style="background:#fff;border-radius:16px;padding:20px 28px;flex:1;min-width:140px;box-shadow:0 2px 8px rgba(0,0,0,.06)">
                <p style="font-size:13px;color:#6F6F6F;font-family:'DM Sans',sans-serif;margin-bottom:4px">Total Users</p>
                <p style="font-size:28px;font-weight:700;font-family:'Poppins',sans-serif;color:#27252F">@totalUsers</p>
            </div>
            <div style="background:#fff;border-radius:16px;padding:20px 28px;flex:1;min-width:140px;box-shadow:0 2px 8px rgba(0,0,0,.06)">
                <p style="font-size:13px;color:#6F6F6F;font-family:'DM Sans',sans-serif;margin-bottom:4px">Members</p>
                <p style="font-size:28px;font-weight:700;font-family:'Poppins',sans-serif;color:#27252F">@members</p>
            </div>
            <div style="background:#fff;border-radius:16px;padding:20px 28px;flex:1;min-width:140px;box-shadow:0 2px 8px rgba(0,0,0,.06)">
                <p style="font-size:13px;color:#6F6F6F;font-family:'DM Sans',sans-serif;margin-bottom:4px">Admins</p>
                <p style="font-size:28px;font-weight:700;font-family:'Poppins',sans-serif;color:#D6EB31">@admins</p>
            </div>
        </div>

        <!-- Users Table -->
        <div class="admin-panel">
            <h2 class="admin-panel-title">
                All Users
                <span class="admin-count">@Model.Count()</span>
            </h2>

            @if (!Model.Any())
            {
                <p class="admin-empty">No users found.</p>
            }
            else
            {
                <div class="table-wrap">
                    <table class="admin-table" aria-label="Users">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Membership</th>
                                <th>Joined</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.OrderBy(u => u.CreatedAt))
                            {
                                var isAdmin = user.Role == "Admin";
                                <tr>
                                    <td>
                                        <span class="admin-table-title">@user.FullName</span>
                                        @if (!string.IsNullOrEmpty(user.PhoneNumber))
                                        {
                                            <span class="admin-table-sub">@user.PhoneNumber</span>
                                        }
                                    </td>
                                    <td style="font-family:'DM Sans',sans-serif;font-size:14px;color:#27252F">@user.Email</td>
                                    <td>
                                        <span class="badge @(isAdmin ? "badge-warning" : "badge-success")" style="font-size:12px">
                                            @user.Role
                                        </span>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(user.MembershipPlanName))
                                        {
                                            <span class="badge badge-success" style="font-size:12px">@user.MembershipPlanName</span>
                                        }
                                        else
                                        {
                                            <span style="font-size:13px;color:#6F6F6F">None</span>
                                        }
                                    </td>
                                    <td style="font-size:13px;color:#6F6F6F;white-space:nowrap">@user.CreatedAt.ToString("MMM d, yyyy")</td>
                                    <td>
                                        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
                                            <!-- Change Role -->
                                            <form method="post" asp-controller="Admin" asp-action="ChangeRole" asp-route-id="@user.Id" style="display:flex;gap:6px;align-items:center">
                                                @Html.AntiForgeryToken()
                                                <select name="role" style="border:1px solid #E6E6E6;border-radius:8px;padding:5px 10px;font-family:'DM Sans',sans-serif;font-size:13px;color:#27252F;background:#fff;cursor:pointer">
                                                    <option value="Member" selected="@(user.Role == "Member")">Member</option>
                                                    <option value="Admin" selected="@(user.Role == "Admin")">Admin</option>
                                                </select>
                                                <button type="submit" style="background:#D6EB31;border:none;border-radius:8px;padding:6px 12px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;color:#27252F;cursor:pointer;white-space:nowrap">
                                                    Save
                                                </button>
                                            </form>

                                            <!-- Delete -->
                                            @if (!isAdmin)
                                            {
                                                <form method="post" asp-controller="Admin" asp-action="DeleteUser" asp-route-id="@user.Id"
                                                      onsubmit="return confirm('Are you sure you want to delete @user.FullName? This action cannot be undone.')">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="admin-delete-btn">Delete</button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>