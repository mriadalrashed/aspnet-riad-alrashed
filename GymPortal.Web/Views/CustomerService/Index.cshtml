@model GymPortal.Web.ViewModels.CustomerServiceViewModel
@{
    ViewData["Title"] = "Customer Service";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="cs-page">
    <h1 class="cs-section-title">Customer Service</h1>

    <!-- Figma: contact section — image left 610×786 + form right, white card 1320×786, border-radius 20px -->
    <div class="cs-contact-grid">
        <!-- Left: contact image with overlay -->
        <div class="cs-image-panel">
            <img src="/images/contact-us.png" alt="Contact CoreFitness" class="cs-contact-img" />
            <!-- Figma: rgba(64,64,64,0.75) backdrop-blur 15px, border-radius 20px -->
            <div class="cs-contact-overlay">
                <div class="cs-contact-info-item">
                    <!-- Figma: Ellipse #D6EB31 50×50 -->
                    <div class="cs-contact-info-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" /></svg>
                    </div>
                    <div>
                        <p class="cs-contact-info-label">Phone Number</p>
                        <p class="cs-contact-info-value">+(46) 0 000 000 00</p>
                    </div>
                </div>
                <div class="cs-contact-info-item">
                    <div class="cs-contact-info-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg>
                    </div>
                    <div>
                        <p class="cs-contact-info-label">Email Address</p>
                        <p class="cs-contact-info-value">info@@corefitness.se</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: contact form -->
        <div class="cs-form-panel">
            <!-- Figma: "Contact Us Today" Poppins 600 28px -->
            <h2 class="cs-form-heading">Contact Us Today</h2>
            <p class="cs-form-sub">Ready to begin your fitness journey? Contact CoreFitness today and let our expert trainers guide you with the right program and support.</p>

            @if (ViewData["SuccessMessage"] != null)
            {
                <div class="alert alert--success" style="margin-bottom:20px;">
                    <span>@ViewData["SuccessMessage"]</span>
                </div>
            }

            <form method="post" asp-action="Contact" asp-controller="CustomerService" novalidate>
                @Html.AntiForgeryToken()

                <!-- Figma: 2-col row: First Name + Last Name -->
                <div class="cs-form-row">
                    <div class="cs-form-group">
                        <label class="cs-label">First Name *</label>
                        <input name="FirstName" class="cs-input" type="text" autocomplete="given-name" placeholder="Enter First Name" required />
                    </div>
                    <div class="cs-form-group">
                        <label class="cs-label">Last Name *</label>
                        <input name="LastName" class="cs-input" type="text" autocomplete="family-name" placeholder="Enter Last Name" required />
                    </div>
                </div>

                <!-- Figma: 2-col row: Email + Phone -->
                <div class="cs-form-row" style="margin-top:0">
                    <div class="cs-form-group">
                        <label class="cs-label">Email Address *</label>
                        <input name="Email" class="cs-input" type="email" autocomplete="email" placeholder="Enter Email Address" required />
                    </div>
                    <div class="cs-form-group">
                        <label class="cs-label">Phone Number</label>
                        <input name="PhoneNumber" class="cs-input" type="tel" autocomplete="tel" placeholder="Enter Phone Number" />
                    </div>
                </div>

                <!-- Figma: Message textarea 157px -->
                <div class="cs-form-group">
                    <label class="cs-label">Message *</label>
                    <textarea name="Message" class="cs-textarea" placeholder="Message..." required></textarea>
                </div>

                <!-- Figma: Submit btn 199×50 #D6EB31 -->
                <button type="submit" class="cs-submit-btn">
                    Submit Message
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                </button>
            </form>
        </div>
    </div>

    <!-- Figma: FAQ section — image left 630×748, accordion right -->
    <div class="cs-faq-section">
        <img src="/images/faq-gym.png" alt="FAQ" class="cs-faq-image" loading="lazy" />

        <div class="cs-faq-content">
            <div class="memberships-faq-badge">
                <span class="memberships-faq-badge-dot"></span>
                <span class="memberships-faq-badge-text">Frequently Asked Questions</span>
            </div>
            <h2 class="memberships-faq-title">Common questions about<br />gym and training</h2>

            <div>
                <div class="faq-item open">
                    <button class="faq-question" onclick="toggleFaq(this)" type="button">
                        <span class="faq-question-text">Q1. Do I need prior gym experience to Join CoreFitness?</span>
                        <span class="faq-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9" /></svg></span>
                    </button>
                    <div class="faq-answer">
                        <p class="faq-answer-text">No, CoreFitness is designed for all fitness levels. Our trainers guide beginners with proper techniques and structured workout plans.</p>
                        <ul class="faq-answer-list">
                            <li class="faq-answer-list-item"><span class="faq-answer-dot"></span><span class="faq-answer-list-text">Every new member receives a personalized introduction to equipments</span></li>
                            <li class="faq-answer-list-item"><span class="faq-answer-dot"></span><span class="faq-answer-list-text">Workouts are designed to grow with you, ensuring beginners can start safely.</span></li>
                        </ul>
                    </div>
                </div>
                <div class="faq-item">
                    <button class="faq-question" onclick="toggleFaq(this)" type="button">
                        <span class="faq-question-text">Q2. What facilities are included with the membership?</span>
                        <span class="faq-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9" /></svg></span>
                    </button>
                    <div class="faq-answer">
                        <p class="faq-answer-text">All memberships include access to our full gym floor, group classes, locker rooms, and showers.</p>
                    </div>
                </div>
                <div class="faq-item">
                    <button class="faq-question" onclick="toggleFaq(this)" type="button">
                        <span class="faq-question-text">Q3. Can I try the gym before taking a membership?</span>
                        <span class="faq-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9" /></svg></span>
                    </button>
                    <div class="faq-answer">
                        <p class="faq-answer-text">Yes! Every new membership comes with a 1-week free trial so you can experience the gym before committing.</p>
                    </div>
                </div>
                <div class="faq-item">
                    <button class="faq-question" onclick="toggleFaq(this)" type="button">
                        <span class="faq-question-text">Q4. Are there group workout programs available?</span>
                        <span class="faq-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9" /></svg></span>
                    </button>
                    <div class="faq-answer">
                        <p class="faq-answer-text">Absolutely. We offer 120+ weekly group classes including HIIT, Yoga, Spin, Boxing, and more.</p>
                    </div>
                </div>
                <div class="faq-item">
                    <button class="faq-question" onclick="toggleFaq(this)" type="button">
                        <span class="faq-question-text">Q5. Is nutrition guidance included in the plans?</span>
                        <span class="faq-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9" /></svg></span>
                    </button>
                    <div class="faq-answer">
                        <p class="faq-answer-text">Premium and Elite plans include monthly nutrition consultations. Standard plans have access to our online nutrition resources.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleFaq(btn) {
            var item = btn.parentElement;
            var isOpen = item.classList.contains('open');
            document.querySelectorAll('.faq-item').forEach(function(i){ i.classList.remove('open'); });
            if (!isOpen) item.classList.add('open');
        }
    </script>
}
