*.psd
*.ai
*.mp4
*.zip

# Development-only files
wwwroot/dev-assets/
appsettings.*.json
*.db

# Logs
*.log

# OS Files
.DS_Store
Thumbs.db

# Node (if using npm)
node_modules/

# Backup / temp files
*.bak
*.tmp
*.swp